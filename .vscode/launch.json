{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Tests cli",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${workspaceFolder}/erun-cli/src/test/go/cmd",
            "cwd": "${workspaceFolder}/erun-cli",
            "env": {
                "GOWORK": "${workspaceFolder}/erun-cli/go.work"
            }
        },
        {
            "name": "Debug cli",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/erun-cli",
            "cwd": "${workspaceFolder}/erun-cli",
            "stopOnEntry":false,
            "env": {
                "GOWORK": "${workspaceFolder}/erun-cli/go.work"
            }
        },
    ]
}
